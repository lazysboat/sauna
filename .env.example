# --- Claude (the agent) ---
ANTHROPIC_API_KEY=sk-ant-...
# Model the agent uses. Default is the most capable; swap for cheaper/faster demos:
#   claude-opus-4-8    (best quality, default)
#   claude-sonnet-4-6  (balanced)
#   claude-haiku-4-5   (fastest / cheapest)
CLAUDE_MODEL=claude-opus-4-8

# --- ClickHouse Cloud ---
# From your ClickHouse Cloud service "Connect" panel (HTTPS endpoint).
CLICKHOUSE_HOST=xxxxxxxx.region.provider.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true
